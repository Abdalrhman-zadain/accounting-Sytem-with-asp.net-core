DATABASE_URL="postgresql://simple_account_user:simple_account_pass@localhost:15433/simple-account-pos-m-ch?schema=public"
PORT=3007
INVENTORY_ACCOUNTING_ENABLED=true
JWT_EXPIRATION=1d

# QZ Tray silent printing (optional). Run: npm run qz:generate-cert
# QZ_CERT_PATH=./certs/qz/digital-certificate.txt
# QZ_PRIVATE_KEY_PATH=./certs/qz/private-key.pem
# Set to false to skip signing (unsigned QZ / browser print fallback only)
# QZ_SIGNING_ENABLED=false

# POS customer receipt branding (optional overrides; Karshanji defaults apply when unset)
# POS_RECEIPT_COMPANY_NAME="كرشنجي"
# POS_RECEIPT_TAX_NUMBER=""
# POS_RECEIPT_PHONE="079 120 84 88"
# POS_RECEIPT_ADDRESS="عمان - شارع القدس - إشارة الرئيسي مقابل قاعات شذى للأفراح"
# POS_RECEIPT_TAGLINE="كرشات - مقادم - روس - فوارغ - طحالات - سناكات"
