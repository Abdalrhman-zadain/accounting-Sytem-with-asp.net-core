{
  "name": "simple-account-backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.build.json && rm -rf dist/generated/prisma && mkdir -p dist/generated && cp -R src/generated/prisma dist/generated/prisma",
    "start": "node dist/main.js",
    "start:dev": "ts-node-dev --respawn --transpile-only --poll src/main.ts",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "db:up": "docker compose -f ../docker-compose.yml up -d postgres",
    "db:down": "docker compose -f ../docker-compose.yml down",
    "prisma:generate": "prisma generate --generator client",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:format": "prisma format",
    "prisma:migrate": "prisma migrate dev --skip-generate",
    "prisma:studio": "prisma studio",
    "seed:cashier": "ts-node prisma/setup-pos-cashier.ts",
    "seed:kitchen": "ts-node prisma/setup-pos-kitchen.ts",
    "seed:waiter": "ts-node prisma/setup-pos-waiter.ts",
    "seed:pos-demo": "ts-node prisma/seed-pos-demo.ts",
    "seed:pos-addons": "ts-node prisma/seed-pos-addons-only.ts",
    "seed:market": "ts-node prisma/seed-pos-market.ts",
    "seed:shouq": "ts-node prisma/seed-shouq-catalog.ts",
    "clear:shouq": "ts-node prisma/clear-shouq-catalog.ts",
    "clear:shouq-stock": "ts-node prisma/clear-item-inventory-stock.ts",
    "clear:market-demo": "ts-node prisma/clear-legacy-market-demo.ts",
    "refresh:shouq-catalog": "npm run clear:shouq && npm run clear:market-demo && npm run seed:shouq && npm run clear:shouq-stock",
    "seed:market-cashier": "ts-node prisma/setup-pos-market-cashier.ts",
    "seed:market-showcase": "ts-node prisma/seed-market-showcase.ts",
    "prisma:migrate:account-codes:6-to-7": "ts-node prisma/migrate-6-to-7-digit-account-codes.ts",
    "seed": "ts-node prisma/seed.ts",
    "seed:volume": "ts-node prisma/seed-volume.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.6",
    "@nestjs/core": "^11.1.6",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.6",
    "@nestjs/swagger": "^11.2.7",
    "@prisma/client": "^6.6.0",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.6",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.1",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.14.1",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^7.2.0",
    "jest": "^29.7.0",
    "prisma": "^6.6.0",
    "prisma-erd-generator": "^2.0.4",
    "supertest": "^7.1.0",
    "ts-jest": "^29.2.6",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.8.3",
    "xlsx": "^0.18.5"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  }
}
