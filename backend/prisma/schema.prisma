  amount            Decimal          @db.Decimal(18, 2)
  tenderedAmount    Decimal?         @db.Decimal(18, 2)
  reference         String?

  // Delivery Company details (e.g. Talabat, Careem)
  deliveryCompanyId String?
  deliveryCompany   DeliveryCompany? @relation(fields: [deliveryCompanyId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())

  @@index([salesInvoiceId])
  @@index([bankCashAccountId])
  @@index([paymentMethod])
}

model PosRuntimeSetting {
  key       String   @id
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PosReturn {
  id               String              @id @default(cuid())
  reference        String              @unique
  status           PosReturnStatus     @default(COMPLETED)
  returnDate       DateTime
  salesInvoiceId   String
  salesInvoice     SalesInvoice        @relation(fields: [salesInvoiceId], references: [id], onDelete: Restrict)
  posSessionId     String?
  posSession       PosSession?         @relation(fields: [posSessionId], references: [id], onDelete: SetNull)
  customerId       String
  customer         Customer            @relation(fields: [customerId], references: [id], onDelete: Restrict)
  currencyCode     String              @default("JOD")
  reason           String?
  subtotalAmount   Decimal             @default(0) @db.Decimal(18, 2)
  discountAmount   Decimal             @default(0) @db.Decimal(18, 2)
  taxAmount        Decimal             @default(0) @db.Decimal(18, 2)
  totalAmount      Decimal             @default(0) @db.Decimal(18, 2)
  refundAmount     Decimal             @default(0) @db.Decimal(18, 2)
  accountingStatus PosAccountingStatus @default(PENDING_REVIEW)
  journalEntryId   String?             @unique
  journalEntry     JournalEntry?       @relation("PosReturnToJournalEntry", fields: [journalEntryId], references: [id], onDelete: Restrict)
  reviewedAt       DateTime?
  reviewedByUserId String?
  reviewedByUser   User?               @relation("PosReturnReviewedByUser", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  reviewNotes      String?
  postedAt         DateTime?
  reversedAt       DateTime?
  createdByUserId  String?
  createdByUser    User?               @relation("PosReturnCreatedByUser", fields: [createdByUserId], references: [id], onDelete: SetNull)
  lines            PosReturnLine[]
  payments         PosReturnPayment[]
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  @@index([salesInvoiceId, returnDate])
  @@index([posSessionId])
  @@index([customerId])
  @@index([accountingStatus, returnDate])
}

model PosReturnLine {
