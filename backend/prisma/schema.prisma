  confirmedByUserId        String?
  confirmedByUser          User?                    @relation("DeliverySettlementConfirmedByUser", fields: [confirmedByUserId], references: [id], onDelete: SetNull)
  reversedByUserId         String?
  reversedByUser           User?                    @relation("DeliverySettlementReversedByUser", fields: [reversedByUserId], references: [id], onDelete: SetNull)
  reversedAt               DateTime?
  createdAt                DateTime                 @default(now())
  updatedAt                DateTime                 @updatedAt
  orders                   DeliveryCompanySettlementOrder[]

  @@index([deliveryCompanyId, periodFrom, periodTo])
  @@index([bankCashAccountId])
  @@index([settlementDate])
