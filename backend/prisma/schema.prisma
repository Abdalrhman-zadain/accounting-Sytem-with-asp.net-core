  reference                String                   @unique
  deliveryCompanyId        String
  deliveryCompany          DeliveryCompany          @relation(fields: [deliveryCompanyId], references: [id], onDelete: Restrict)
  periodFrom               DateTime
  periodTo                 DateTime
  settlementDate           DateTime
  statementReference       String?
  bankCashAccountId        String
  bankCashAccount          BankCashAccount          @relation(fields: [bankCashAccountId], references: [id], onDelete: Restrict)
  statementAmount          Decimal                  @default(0) @db.Decimal(18, 2)
  grossOrdersAmount        Decimal                  @default(0) @db.Decimal(18, 2)
  commissionAmount         Decimal                  @default(0) @db.Decimal(18, 2)
  serviceFeeAmount         Decimal                  @default(0) @db.Decimal(18, 2)
  refundAmount             Decimal                  @default(0) @db.Decimal(18, 2)
  adjustmentAmount         Decimal                  @default(0) @db.Decimal(18, 2)
  differenceAmount         Decimal                  @default(0) @db.Decimal(18, 2)
  differenceReason         String?
  differenceAccountId      String?
  differenceAccount        Account?                 @relation("DeliverySettlementDifferenceAccount", fields: [differenceAccountId], references: [id], onDelete: Restrict)
  differenceNotes          String?
  netReceivedAmount        Decimal                  @default(0) @db.Decimal(18, 2)
  statementAttachmentUrl   String?
  bankReceiptAttachmentUrl String?
  journalEntryId           String?                  @unique
