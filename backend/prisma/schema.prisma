  tableId String
  table   PosTable @relation(fields: [tableId], references: [id], onDelete: Cascade)

  reservedFrom DateTime
  reservedTo   DateTime

  status          PosTableReservationStatus @default(ACTIVE)
  notes           String?
  createdByUserId String?
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt

