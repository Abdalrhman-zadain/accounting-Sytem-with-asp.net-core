model JournalEntry {
  id          String             @id @default(cuid())
  reference   String             @unique
  description String?
  entryDate   DateTime
  status      JournalEntryStatus @default(DRAFT)
  postedAt    DateTime?

  journalEntryTypeId String?
  journalEntryType   JournalEntryType? @relation(fields: [journalEntryTypeId], references: [id])

  fiscalPeriodId String?
  fiscalPeriod   FiscalPeriod? @relation(fields: [fiscalPeriodId], references: [id])

  reversalOfId              String?                    @unique
  reversalOf                JournalEntry?              @relation("JournalEntryReversal", fields: [reversalOfId], references: [id])
  reversedBy                JournalEntry?              @relation("JournalEntryReversal")
  lines                     JournalEntryLine[]
  ledgerLines               LedgerTransaction[]
