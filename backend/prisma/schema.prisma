model SalesInvoice {
  id                   String                @id @default(cuid())
  reference            String                @unique
  status               SalesInvoiceStatus    @default(DRAFT)
  invoiceType          SalesInvoiceType      @default(STANDARD)
  invoiceDate          DateTime
  dueDate              DateTime?
  customerId           String
  customer             Customer              @relation(fields: [customerId], references: [id], onDelete: Restrict)
  currencyCode         String                @default("JOD")
  description          String?
  sourceQuotationId    String?
  sourceQuotation      SalesQuotation?       @relation("InvoiceSourceQuotation", fields: [sourceQuotationId], references: [id], onDelete: Restrict)
  sourceSalesOrderId   String?
  sourceSalesOrder     SalesOrder?           @relation("InvoiceSourceSalesOrder", fields: [sourceSalesOrderId], references: [id], onDelete: Restrict)
  subtotalAmount       Decimal               @default(0) @db.Decimal(18, 2)
  discountAmount       Decimal               @default(0) @db.Decimal(18, 2)
  taxAmount            Decimal               @default(0) @db.Decimal(18, 2)
  totalAmount          Decimal               @default(0) @db.Decimal(18, 2)
  allocatedAmount      Decimal               @default(0) @db.Decimal(18, 2)
  outstandingAmount    Decimal               @default(0) @db.Decimal(18, 2)
  allocationStatus     AllocationStatus      @default(UNALLOCATED)
  posOperationalStatus PosOperationalStatus?
  posAccountingStatus  PosAccountingStatus?
  posSessionId         String?
  posSession           PosSession?           @relation(fields: [posSessionId], references: [id], onDelete: SetNull)
  posReceiptNumber     String?               @unique
  posCompletedAt       DateTime?
  posVoidedAt          DateTime?
  posVoidReason        String?
  posReviewedAt        DateTime?
  posReviewedByUserId  String?
  posReviewedByUser    User?                 @relation("PosReviewedByUser", fields: [posReviewedByUserId], references: [id], onDelete: SetNull)
  posReviewNotes       String?
  posChangeAmount      Decimal?              @db.Decimal(18, 2)
  posPayments          PosPayment[]
  posReturns           PosReturn[]
  journalEntryId       String?               @unique
  journalEntry         JournalEntry?         @relation("SalesInvoiceToJournalEntry", fields: [journalEntryId], references: [id], onDelete: Restrict)
  lines                SalesInvoiceLine[]
  creditNotes          CreditNote[]
  receiptAllocations   ReceiptAllocation[]
  postedAt             DateTime?

  // Restaurant POS fields
  orderType           OrderType?
  tableId             String?
  table               PosTable?        @relation("TableInvoiceHistory", fields: [tableId], references: [id], onDelete: Restrict)
  activeTable         PosTable?        @relation("TableActiveInvoice")
  waiterId            String?
  waiter              User?            @relation("InvoiceWaiter", fields: [waiterId], references: [id], onDelete: SetNull)
  serviceChargeAmount Decimal?         @default(0) @db.Decimal(18, 2)
  deliveryFeeAmount   Decimal?         @default(0) @db.Decimal(18, 2)
  driverId            String?
  driver              DeliveryDriver?  @relation(fields: [driverId], references: [id], onDelete: SetNull)
  deliveryStatus      DeliveryStatus?
  deliveryAddress     String?
  deliveryNotes       String?
  deliveryCompanyId   String?
  deliveryCompany     DeliveryCompany? @relation(fields: [deliveryCompanyId], references: [id], onDelete: Restrict)
  deliveryCollectionMethod DeliveryCollectionMethod?
  deliverySettlementStatus DeliverySettlementStatus?
  deliverySettledAmount    Decimal?                  @default(0) @db.Decimal(18, 2)
  kitchenOrder        KitchenOrder?
  deliverySettlementOrders DeliveryCompanySettlementOrder[]
  waiterConfirmedAt   DateTime?

  // Audits & Corrections
  originalOrderType OrderType?
  correctionReason  String?
  isCorrected       Boolean    @default(false)
  correctedAt       DateTime?
  correctedByUserId String?
  correctedByUser   User?      @relation("InvoiceCorrector", fields: [correctedByUserId], references: [id], onDelete: SetNull)

  posAmendedFromInvoiceId String?
  posAmendedFromInvoice   SalesInvoice?  @relation("PosInvoiceAmendmentChain", fields: [posAmendedFromInvoiceId], references: [id], onDelete: SetNull)
  posAmendedToInvoiceId   String?
  posAmendedToInvoice     SalesInvoice?  @relation("PosInvoiceAmendmentReplacement", fields: [posAmendedToInvoiceId], references: [id], onDelete: SetNull)
  posAmendmentReplacements SalesInvoice[] @relation("PosInvoiceAmendmentChain")
  posAmendmentSources      SalesInvoice[] @relation("PosInvoiceAmendmentReplacement")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerId, status, invoiceDate])
  @@index([allocationStatus])
  @@index([sourceQuotationId])
  @@index([sourceSalesOrderId])
  @@index([invoiceType, posOperationalStatus, invoiceDate])
  @@index([invoiceType, posAccountingStatus, invoiceDate])
  @@index([posSessionId])
  @@index([posAmendedFromInvoiceId])
  @@index([posAmendedToInvoiceId])
}

