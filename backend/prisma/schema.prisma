  @@index([salesInvoiceLineId])
  @@index([itemId])
  @@index([warehouseId])
  @@index([taxId])
}

model PosReturnPayment {
  id                String           @id @default(cuid())
  posReturnId       String
  posReturn         PosReturn        @relation(fields: [posReturnId], references: [id], onDelete: Cascade)
  refundMethod      PosRefundMethod
  bankCashAccountId String?
  bankCashAccount   BankCashAccount? @relation(fields: [bankCashAccountId], references: [id], onDelete: Restrict)
  amount            Decimal          @db.Decimal(18, 2)
  reference         String?
  createdAt         DateTime         @default(now())

  @@index([posReturnId])
  @@index([bankCashAccountId])
  @@index([refundMethod])
}

model SalesInvoiceLine {
  id                 String              @id @default(cuid())
  salesInvoiceId     String
  salesInvoice       SalesInvoice        @relation(fields: [salesInvoiceId], references: [id], onDelete: Cascade)
  lineNumber         Int
  itemId             String?
  item               InventoryItem?      @relation(fields: [itemId], references: [id], onDelete: Restrict)
  warehouseId        String?
  warehouse          InventoryWarehouse? @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  itemName           String?
  description        String?
  quantity           Decimal             @default(1) @db.Decimal(18, 4)
  unitPrice          Decimal             @db.Decimal(18, 2)
  discountAmount     Decimal             @default(0) @db.Decimal(18, 2)
  taxId              String?
  tax                Tax?                @relation(fields: [taxId], references: [id], onDelete: Restrict)
  taxAmount          Decimal             @default(0) @db.Decimal(18, 2)
  lineSubtotalAmount Decimal             @db.Decimal(18, 2)
  lineAmount         Decimal             @db.Decimal(18, 2)
  revenueAccountId   String
  revenueAccount     Account             @relation("SalesInvoiceRevenueAccount", fields: [revenueAccountId], references: [id], onDelete: Restrict)

