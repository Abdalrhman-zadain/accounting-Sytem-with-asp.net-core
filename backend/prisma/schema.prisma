  submittedByUserId String?
  submittedByUser   User?     @relation("SessionSubmitter", fields: [submittedByUserId], references: [id], onDelete: SetNull)

  // Accountant Decision fields
  differenceStatus  String?  // e.g. "ACCEPTED_DIFFERENCE"
  reviewStatus      String?  // e.g. "APPROVED", "CORRECTION_REQUESTED", "REJECTED"
  acceptedByUserId  String?
  acceptedByUser    User?            @relation("SessionAcceptor", fields: [acceptedByUserId], references: [id], onDelete: SetNull)
  acceptedAt        DateTime?
  acceptanceReason  String?
  rejectionReason   String?

  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([cashierUserId, status, openedAt])
  @@index([warehouseId, status])
  @@index([salesRepId, status])
  @@index([posProduct, status, openedAt])
  @@index([cashierUserId, posProduct, status])
}

model PosPayment {
  id                String           @id @default(cuid())
  salesInvoiceId    String
  salesInvoice      SalesInvoice     @relation(fields: [salesInvoiceId], references: [id], onDelete: Cascade)
  bankCashAccountId String
