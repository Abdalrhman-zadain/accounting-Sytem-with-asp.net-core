  salesInvoiceId        String
  salesInvoice          SalesInvoice        @relation(fields: [salesInvoiceId], references: [id], onDelete: Restrict)
  bankCashTransactionId String
  bankCashTransaction   BankCashTransaction @relation("ReceiptTransactionAllocations", fields: [bankCashTransactionId], references: [id], onDelete: Restrict)
  amount                Decimal             @db.Decimal(18, 2)
  allocatedAt           DateTime            @default(now())
  createdAt             DateTime            @default(now())

  @@unique([salesInvoiceId, bankCashTransactionId])
  @@index([bankCashTransactionId])
}

model JournalEntryLine {
  id             String              @id @default(cuid())
  journalEntryId String
  accountId      String
  lineNumber     Int
  description    String?
  debitAmount    Decimal             @db.Decimal(18, 2)
  creditAmount   Decimal             @db.Decimal(18, 2)
  journalEntry   JournalEntry        @relation(fields: [journalEntryId], references: [id], onDelete: Restrict)
  account        Account             @relation(fields: [accountId], references: [id], onDelete: Restrict)
  ledgerLines    LedgerTransaction[]
  createdAt      DateTime            @default(now())

  @@unique([journalEntryId, lineNumber])
  @@index([accountId])
}

model PostingBatch {
  id           String              @id @default(cuid())
  postedAt     DateTime            @default(now())
  journalEntry JournalEntry?
  ledgerLines  LedgerTransaction[]
  createdAt    DateTime            @default(now())

  @@index([postedAt])
}

model LedgerTransaction {
  id                 String   @id @default(cuid())
  postingBatchId     String
  journalEntryId     String
  journalEntryLineId String
  accountId          String
  reference          String
  entryDate          DateTime
  postedAt           DateTime
  description        String?
  debitAmount        Decimal  @db.Decimal(18, 2)
  creditAmount       Decimal  @db.Decimal(18, 2)

  fiscalPeriodId String?
  fiscalPeriod   FiscalPeriod? @relation(fields: [fiscalPeriodId], references: [id])

  postingBatch              PostingBatch              @relation(fields: [postingBatchId], references: [id], onDelete: Restrict)
  journalEntry              JournalEntry              @relation(fields: [journalEntryId], references: [id], onDelete: Restrict)
  journalEntryLine          JournalEntryLine          @relation(fields: [journalEntryLineId], references: [id], onDelete: Restrict)
  account                   Account                   @relation(fields: [accountId], references: [id], onDelete: Restrict)
  bankReconciliationMatches BankReconciliationMatch[]

  createdById String?
  createdBy   User?   @relation("LedgerCreator", fields: [createdById], references: [id])

  createdAt DateTime @default(now())

  @@index([accountId, entryDate, postedAt])
  @@index([journalEntryId])
  @@index([reference])
  @@index([fiscalPeriodId])
}

model FiscalYear {
  id        String         @id @default(cuid())
  year      Int            @unique
  startDate DateTime
  endDate   DateTime
  status    PeriodStatus   @default(OPEN)
  periods   FiscalPeriod[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model FiscalPeriod {
  id           String              @id @default(cuid())
  fiscalYearId String
  fiscalYear   FiscalYear          @relation(fields: [fiscalYearId], references: [id])
  periodNumber Int
  name         String
  startDate    DateTime
  endDate      DateTime
  status       PeriodStatus        @default(OPEN)
  entries      JournalEntry[]
  ledgerLines  LedgerTransaction[]
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@unique([fiscalYearId, periodNumber])
}

model SegmentDefinition {
  id          String         @id @default(cuid())
  index       Int            @unique // 1 to 5
  name        String // e.g. Department
  description String?
  values      SegmentValue[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model SegmentValue {
  id           String            @id @default(cuid())
  definitionId String
  definition   SegmentDefinition @relation(fields: [definitionId], references: [id])
  code         String
  name         String
  isActive     Boolean           @default(true)

  accountsAsS1 Account[] @relation("Segment1")
  accountsAsS2 Account[] @relation("Segment2")
  accountsAsS3 Account[] @relation("Segment3")
  accountsAsS4 Account[] @relation("Segment4")
  accountsAsS5 Account[] @relation("Segment5")

  // Link users to their primary company (where definition.index = 1)
  users User[] @relation("UserAtCompany")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([definitionId, code])
}

enum UserRole {
  ADMIN // Global SuperAdmin
  MANAGER // Company Root User
  USER // Company Accountant
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  POST
  REVERSE
  OPEN
  CLOSE
  VIEW
}

model AuditLog {
  id       String      @id @default(cuid())
  userId   String?
  user     User?       @relation(fields: [userId], references: [id])
  entity   String // e.g. "Account", "JournalEntry"
  entityId String?
  action   AuditAction
  details  Json?

  // Explicitly scoped to company for fast filtering
  companyId String?

  createdAt DateTime @default(now())

  @@index([entity, entityId])
  @@index([userId])
  @@index([companyId])
  @@index([createdAt])
}

model User {
  id       String   @id @default(cuid())
  username String   @unique
  email    String   @unique
  password String
  name     String?
  role     UserRole @default(USER)
  isActive Boolean  @default(true)

  // Multi-Tenancy
  companyId String?
  company   SegmentValue? @relation("UserAtCompany", fields: [companyId], references: [id])

  // Hierarchical Management
  parentUserId  String?
  parentUser    User?   @relation("UserHierarchy", fields: [parentUserId], references: [id])
  childrenUsers User[]  @relation("UserHierarchy")

  salesRepId   String?
  salesRep     SalesRepresentative? @relation("UserSalesRepresentative", fields: [salesRepId], references: [id], onDelete: SetNull)

  createdAccounts                     Account[]                      @relation("AccountCreator")
  updatedAccounts                     Account[]                      @relation("AccountUpdater")
  createdJournals                     JournalEntry[]                 @relation("JournalCreator")
  createdLedgerLines                  LedgerTransaction[]            @relation("LedgerCreator")
  purchaseRequestStatusHistoryEntries PurchaseRequestStatusHistory[] @relation("UserPurchaseRequestStatusHistory")
  posSessions                         PosSession[]                   @relation("PosSessionCashier")
  reviewedPosSales                    SalesInvoice[]                 @relation("PosReviewedByUser")
  createdPosReturns                   PosReturn[]                    @relation("PosReturnCreatedByUser")
  reviewedPosReturns                  PosReturn[]                    @relation("PosReturnReviewedByUser")
  posAccessRoles                      UserPosAccessRole[]
  posFavoriteItems                    PosUserFavoriteItem[]
  auditLogs                           AuditLog[]
  createdDeliverySettlements          DeliveryCompanySettlement[]    @relation("DeliverySettlementCreatedByUser")
  confirmedDeliverySettlements        DeliveryCompanySettlement[]    @relation("DeliverySettlementConfirmedByUser")
  reversedDeliverySettlements         DeliveryCompanySettlement[]    @relation("DeliverySettlementReversedByUser")

  // Restaurant POS relations
  tablesServed                        PosTable[]                     @relation("TableWaiter")
  invoicesServed                      SalesInvoice[]                 @relation("InvoiceWaiter")
  correctedInvoices                   SalesInvoice[]                 @relation("InvoiceCorrector")
  submittedSessions                   PosSession[]                   @relation("SessionSubmitter")
  acceptedSessions                    PosSession[]                   @relation("SessionAcceptor")
  postedRepCarLoads                   RepCarLoad[]                   @relation("RepCarLoadPostedBy")
  reversedRepCarLoads                 RepCarLoad[]                   @relation("RepCarLoadReversedBy")
  postedRepCarUnloads                 RepCarUnload[]                 @relation("RepCarUnloadPostedBy")
  postedRepCarTransfers               RepCarTransfer[]               @relation("RepCarTransferPostedBy")
  reversedRepCarTransfers             RepCarTransfer[]               @relation("RepCarTransferReversedBy")
  postedRepCarStocktakes              RepCarStocktake[]              @relation("RepCarStocktakePostedBy")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([username])
  @@index([companyId])
  @@index([salesRepId])
}

model PosUserFavoriteItem {
  id        String        @id @default(cuid())
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  itemId    String
  item      InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  createdAt DateTime      @default(now())

  @@unique([userId, itemId])
  @@index([userId])
  @@index([itemId])
}

model PosTable {
  id               String                @id @default(cuid())
  tableNumber      String                @unique
  capacity         Int
  status           TableStatus           @default(AVAILABLE)
  activeInvoiceId  String?               @unique
  activeInvoice    SalesInvoice?         @relation("TableActiveInvoice", fields: [activeInvoiceId], references: [id], onDelete: SetNull)
  assignedWaiterId String?
  assignedWaiter   User?                 @relation("TableWaiter", fields: [assignedWaiterId], references: [id], onDelete: SetNull)
  reservations     PosTableReservation[]
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  invoices         SalesInvoice[]        @relation("TableInvoiceHistory")
}

enum PosTableReservationStatus {
  ACTIVE
  CANCELLED
  EXPIRED
}

model PosTableReservation {
