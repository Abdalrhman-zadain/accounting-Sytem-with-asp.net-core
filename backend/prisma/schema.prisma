  cogsAccount        Account?            @relation("CreditNoteCogsAccount", fields: [cogsAccountId], references: [id], onDelete: Restrict)
  unitCost           Decimal?            @db.Decimal(18, 4)
  totalCost          Decimal?            @db.Decimal(18, 2)
  createdAt          DateTime            @default(now())

  @@unique([creditNoteId, lineNumber])
