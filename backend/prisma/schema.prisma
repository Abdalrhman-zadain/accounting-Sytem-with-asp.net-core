  posReturnLines  PosReturnLine[]
  kitchenOrderItems KitchenOrderItem[]

  @@unique([salesInvoiceId, lineNumber])
  @@index([itemId])
  @@index([warehouseId])
  @@index([revenueAccountId])
  @@index([taxId])
}

model CreditNote {
  id               String           @id @default(cuid())
  reference        String           @unique
  status           CreditNoteStatus @default(DRAFT)
  noteDate         DateTime
  customerId       String
  customer         Customer         @relation(fields: [customerId], references: [id], onDelete: Restrict)
  salesInvoiceId   String?
  salesInvoice     SalesInvoice?    @relation(fields: [salesInvoiceId], references: [id], onDelete: Restrict)
  creditNoteTypeId String
  creditNoteType   CreditNoteType   @relation(fields: [creditNoteTypeId], references: [id], onDelete: Restrict)
  currencyCode     String           @default("JOD")
  description      String?
  subtotalAmount   Decimal          @default(0) @db.Decimal(18, 2)
  discountAmount   Decimal          @default(0) @db.Decimal(18, 2)
  taxAmount        Decimal          @default(0) @db.Decimal(18, 2)
  totalAmount      Decimal          @default(0) @db.Decimal(18, 2)
  journalEntryId   String?          @unique
  journalEntry     JournalEntry?    @relation("CreditNoteToJournalEntry", fields: [journalEntryId], references: [id], onDelete: Restrict)
  lines            CreditNoteLine[]
  postedAt         DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([customerId, status, noteDate])
  @@index([salesInvoiceId])
  @@index([creditNoteTypeId])
}

model CreditNoteLine {
  id                 String              @id @default(cuid())
  creditNoteId       String
  creditNote         CreditNote          @relation(fields: [creditNoteId], references: [id], onDelete: Cascade)
  lineNumber         Int
  salesInvoiceLineId String?
  salesInvoiceLine   SalesInvoiceLine?   @relation(fields: [salesInvoiceLineId], references: [id], onDelete: Restrict)
  itemId             String?
  item               InventoryItem?      @relation(fields: [itemId], references: [id], onDelete: Restrict)
  warehouseId        String?
  warehouse          InventoryWarehouse? @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  itemName           String?
  description        String?
  quantity           Decimal             @default(1) @db.Decimal(18, 4)
  unitPrice          Decimal             @db.Decimal(18, 2)
  discountAmount     Decimal             @default(0) @db.Decimal(18, 2)
  taxId              String?
  tax                Tax?                @relation(fields: [taxId], references: [id], onDelete: Restrict)
  taxAmount          Decimal             @default(0) @db.Decimal(18, 2)
  originalUnitPrice  Decimal?            @db.Decimal(18, 2)
  correctedUnitPrice Decimal?            @db.Decimal(18, 2)
  originalTaxAmount  Decimal?            @db.Decimal(18, 2)
  correctedTaxAmount Decimal?            @db.Decimal(18, 2)
