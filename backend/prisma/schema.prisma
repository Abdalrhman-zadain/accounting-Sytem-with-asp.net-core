  salesInvoiceLine   SalesInvoiceLine?   @relation(fields: [salesInvoiceLineId], references: [id], onDelete: SetNull)
  itemId             String?
  item               InventoryItem?      @relation(fields: [itemId], references: [id], onDelete: Restrict)
  warehouseId        String?
  warehouse          InventoryWarehouse? @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  itemName           String?
  description        String?
  quantity           Decimal             @default(1) @db.Decimal(18, 4)
  unitPrice          Decimal             @db.Decimal(18, 2)
  discountAmount     Decimal             @default(0) @db.Decimal(18, 2)
  taxId              String?
  tax                Tax?                @relation(fields: [taxId], references: [id], onDelete: Restrict)
  taxAmount          Decimal             @default(0) @db.Decimal(18, 2)
  lineSubtotalAmount Decimal             @db.Decimal(18, 2)
  lineAmount         Decimal             @db.Decimal(18, 2)
  revenueAccountId   String
  revenueAccount     Account             @relation("PosReturnRevenueAccount", fields: [revenueAccountId], references: [id], onDelete: Restrict)
  inventoryAccountId String?
  inventoryAccount   Account?            @relation("PosReturnInventoryAccount", fields: [inventoryAccountId], references: [id], onDelete: Restrict)
  cogsAccountId      String?
  cogsAccount        Account?            @relation("PosReturnCogsAccount", fields: [cogsAccountId], references: [id], onDelete: Restrict)
